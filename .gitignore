!.env.example
firebase-config.json
# GoogleService-Info.plist is NOT ignored: it's the iOS client config that
# @react-native-firebase/app needs at prebuild (and EAS never uploads ignored
# files). It's not a secret — public identifiers + a client API key that's
# restricted by bundle id — and its Android twin (google-services.json) has
# always been committed. Real secrets stay ignored above.

# IDE
.vscode/
.idea/
.DS_Store

# Build
build/
android/
ios/

# Backup and debug files
App_Backup.js
crash_log.txt
functions/firebase-debug.log
firebase-debug.log
firestore-debug.log
.firebase/
# Google service-account keys — private keys, never commit. Patterns cover both
# Firebase's download name (*-firebase-adminsdk-<hash>.json) and the older one
# without the hash, plus the name we keep the FCM V1 key under.
*-firebase-adminsdk-*.json
*-firebase-adminsdk.json
*-fcm-sa.json
google-service-account*.json
cleanup-firebase.js
*.swp

