rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // HELPER FUNCTIONS
    // ============================================
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isEventParticipant(eventId) {
      let eventData = get(/databases/$(database)/documents/events/$(eventId)).data;
      return request.auth.uid == eventData.creatorId ||
             (eventData.attendees != null && request.auth.uid in eventData.attendees);
    }

    function isEventHost(eventId) {
      let eventData = get(/databases/$(database)/documents/events/$(eventId)).data;
      return request.auth.uid == eventData.creatorId ||
             (eventData.coHosts != null && request.auth.uid in eventData.coHosts);
    }

    // An attendee who is NOT the creator — only these users may rate an event.
    function isEventAttendeeNotCreator(eventId) {
      let eventData = get(/databases/$(database)/documents/events/$(eventId)).data;
      return request.auth.uid != eventData.creatorId &&
             eventData.attendees != null &&
             request.auth.uid in eventData.attendees;
    }
    
    function onlyUpdating(allowedFields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowedFields);
    }
    
    // ============================================
    // USERS COLLECTION
    // ============================================
    match /users/{userId} {
      allow read: if isSignedIn();
      // Server-computed reputation fields + the premium entitlement can't be
      // set by the user, not even at account creation.
      allow create: if isSignedIn() && isOwner(userId) &&
                       !request.resource.data.keys()
                          .hasAny(['hostStats', 'carpoolStats', 'isPremium']);

      // The owner can edit their profile but NOT hostStats/carpoolStats (host
      // ratings + loyalty are computed server-side) nor isPremium (the premium
      // entitlement is granted server-side only). Any signed-in user may
      // (un)set a pushToken on any doc, so the login/logout de-dupe can clear
      // stale device tokens.
      allow update: if isAdmin() ||
                       (isOwner(userId) &&
                        !request.resource.data.diff(resource.data)
                          .affectedKeys()
                          .hasAny(['hostStats', 'carpoolStats', 'isPremium'])) ||
                       onlyUpdating(['pushToken', 'pushTokenUpdatedAt']);
      
      allow delete: if isOwner(userId) || isAdmin();
      
      match /stripeConnect/{document=**} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin();
      }
      
      match /notifications/{notificationId} {
        allow read: if isSignedIn() && isOwner(userId);
        allow update: if isSignedIn() && isOwner(userId);
        allow delete: if isSignedIn() && isOwner(userId);
        allow create: if false;
      }
    }
    
    // ============================================
    // EVENTS COLLECTION
    // ============================================
    match /events/{eventId} {
      allow read: if isSignedIn();
      // Hosts can't self-promote for free: featured fields are set only by the
      // server (the promotion payment webhook, via the Admin SDK).
      allow create: if isSignedIn() &&
                       request.resource.data.creatorId == request.auth.uid &&
                       request.resource.data.get('featured', false) == false;

      // - Admin: full control.
      // - Creator: anything except server-owned fields (featured/* and the
      //   rating aggregates, which are written only by Cloud Functions).
      // - Any signed-in user: only the attendees list (to join/leave).
      allow update: if isSignedIn() &&
                       (isAdmin() ||
                        (resource.data.creatorId == request.auth.uid &&
                         !request.resource.data.diff(resource.data)
                           .affectedKeys()
                           .hasAny(['featured', 'featuredUntil', 'featuredTier',
                                    'averageRating', 'totalRatings'])) ||
                        // Co-hosts can edit content, but not server-owned fields
                        // nor ownership (creatorId/coHosts stay creator-managed).
                        (resource.data.coHosts != null &&
                         request.auth.uid in resource.data.coHosts &&
                         !request.resource.data.diff(resource.data)
                           .affectedKeys()
                           .hasAny(['featured', 'featuredUntil', 'featuredTier',
                                    'averageRating', 'totalRatings',
                                    'creatorId', 'coHosts'])) ||
                        onlyUpdating(['attendees']) ||
                        onlyUpdating(['attendees', 'waitlist']) ||
                        onlyUpdating(['waitlist']));
      
      allow delete: if isSignedIn() && 
                       (resource.data.creatorId == request.auth.uid || isAdmin());
      
      match /messages/{messageId} {
        allow read: if isSignedIn() && isEventParticipant(eventId);
        allow create: if isSignedIn() && 
                         isEventParticipant(eventId) &&
                         request.resource.data.senderId == request.auth.uid;
        allow update: if isSignedIn() && isEventParticipant(eventId);
        allow delete: if false;
      }
      
      match /typing/{documentId} {
        allow read: if isSignedIn() && isEventParticipant(eventId);
        allow write: if isSignedIn() && isEventParticipant(eventId);
      }

      // QR check-in — only the event host writes a check-in (scans attendee QR);
      // participants can read (e.g. to see they're checked in). This keeps
      // attendance host-authorized — attendees can't self-check-in.
      match /checkins/{userId} {
        allow read: if isSignedIn() && isEventParticipant(eventId);
        allow write: if isSignedIn() && isEventHost(eventId);
      }

      // Polls — only the host creates/closes; any participant votes (own vote).
      match /polls/{pollId} {
        allow read: if isSignedIn() && isEventParticipant(eventId);
        allow create: if isSignedIn() && isEventHost(eventId) &&
                         request.resource.data.createdBy == request.auth.uid;
        allow update: if isSignedIn() && isEventHost(eventId);
        allow delete: if false;

        match /votes/{userId} {
          allow read: if isSignedIn() && isEventParticipant(eventId);
          allow write: if isSignedIn() &&
                          request.auth.uid == userId &&
                          isEventParticipant(eventId);
        }
      }

      // Car pool — a participant offers a ride; riders request seats.
      match /carpools/{carpoolId} {
        allow read: if isSignedIn() && isEventParticipant(eventId);
        allow create: if isSignedIn() && isEventParticipant(eventId) &&
                         request.resource.data.driverId == request.auth.uid;
        // Only the driver edits/closes their offer.
        allow update: if isSignedIn() &&
                         resource.data.driverId == request.auth.uid;
        allow delete: if false;

        match /riders/{userId} {
          function driverId() {
            return get(/databases/$(database)/documents/events/$(eventId)/carpools/$(carpoolId)).data.driverId;
          }
          allow read: if isSignedIn() && isEventParticipant(eventId);
          allow create: if isSignedIn() && request.auth.uid == userId &&
                           isEventParticipant(eventId);
          // Rider can edit/cancel their own request; driver can approve/decline.
          allow update: if isSignedIn() &&
                           (request.auth.uid == userId ||
                            request.auth.uid == driverId());
          allow delete: if isSignedIn() && request.auth.uid == userId;
        }
      }
    }
    
    // ============================================
    // RATINGS COLLECTION
    // ============================================
    match /ratings/{ratingId} {
      allow read: if isSignedIn();
      // Only an attendee (not the host) of the rated event may create a rating,
      // and only as themselves. Enforced server-side, not just in the client.
      allow create: if isSignedIn() &&
                       request.resource.data.userId == request.auth.uid &&
                       isEventAttendeeNotCreator(request.resource.data.eventId);
      // Ratings are immutable from the client (averages are recomputed by a
      // Cloud Function); the host can't edit/inflate them.
      allow update, delete: if false;

      // Reply thread between the reviewer and the host.
      match /messages/{messageId} {
        function ratingParty() {
          let r = get(/databases/$(database)/documents/ratings/$(ratingId)).data;
          return request.auth.uid == r.userId || request.auth.uid == r.hostId;
        }
        allow read: if isSignedIn() && (ratingParty() || isAdmin());
        allow create: if isSignedIn() &&
                         request.resource.data.senderId == request.auth.uid &&
                         ratingParty();
        allow update, delete: if false;
      }
    }
    
    // ============================================
    // MEMBERSHIP PLANS (host-defined templates)
    // ============================================
    match /membershipPlans/{planId} {
      // Anyone signed in can read (buyers browse a host's plans).
      allow read: if isSignedIn();
      // A host manages only their own plans.
      allow create: if isSignedIn() &&
                       request.resource.data.hostId == request.auth.uid;
      allow update, delete: if isSignedIn() &&
                               resource.data.hostId == request.auth.uid;
    }

    // ============================================
    // MEMBERSHIPS (a user's purchased instance)
    // Credits/expiry are money-sensitive: only the server (Admin SDK via
    // Cloud Functions / webhooks) may create or mutate them.
    // ============================================
    match /memberships/{membershipId} {
      allow read: if isSignedIn() &&
                     (resource.data.userId == request.auth.uid ||
                      resource.data.hostId == request.auth.uid ||
                      isAdmin());
      allow create, update, delete: if false;
    }

    // ============================================
    // MEMBERSHIP REDEMPTIONS (credit-deduction audit trail)
    // Server-only writes (host check-in goes through a Cloud Function).
    // ============================================
    match /membershipRedemptions/{redemptionId} {
      allow read: if isSignedIn() &&
                     (resource.data.userId == request.auth.uid ||
                      resource.data.hostId == request.auth.uid ||
                      isAdmin());
      allow create, update, delete: if false;
    }

    // ============================================
    // MEMBERSHIP RESERVATIONS (credit holds)
    // Created/redeemed/released only via Cloud Functions (Admin SDK).
    // ============================================
    match /membershipReservations/{reservationId} {
      allow read: if isSignedIn() &&
                     (resource.data.userId == request.auth.uid ||
                      resource.data.hostId == request.auth.uid ||
                      isAdmin());
      allow create, update, delete: if false;
    }

    // ============================================
    // PAYMENTS COLLECTION
    // ============================================
    match /payments/{paymentId} {
      allow read: if isSignedIn() && 
                     (resource.data.userId == request.auth.uid || 
                      resource.data.hostId == request.auth.uid || 
                      isAdmin());
      allow create, update, delete: if false;
    }
    
    // ============================================
    // NOTIFICATIONS COLLECTION
    // ============================================
    match /notifications/{notificationId} {
      // Owner can read their notifications
      allow read: if isSignedIn() && 
                     resource.data.userId == request.auth.uid;
      
      // Owner can update their notifications
      allow update: if isSignedIn() && 
                       resource.data.userId == request.auth.uid;
      
      // Owner can delete their notifications
      allow delete: if isSignedIn() && 
                       resource.data.userId == request.auth.uid;
      
      // Any authenticated user can create notifications
      // (needed for rating notifications, event join notifications, etc.)
      allow create: if isSignedIn();
    }

    // Crash/error telemetry: write-only for users, admins read in the console.
    match /crashes/{crashId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && isAdmin();
      allow update, delete: if false;
    }

    // Social graph — follows (foundation for the future feed/posts layer).
    // Doc id = "{followerId}_{followeeId}". You manage only your own follows.
    match /follows/{followId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
                       request.resource.data.followerId == request.auth.uid;
      allow delete: if isSignedIn() &&
                       resource.data.followerId == request.auth.uid;
      allow update: if false;
    }

    // Moderation reports (off-platform payment attempts, host user blocks).
    // Any signed-in user files them (reporterId must be theirs); admins read +
    // resolve. The reporter can read their own.
    match /reports/{reportId} {
      allow create: if isSignedIn() &&
                       request.resource.data.reporterId == request.auth.uid;
      allow read: if isSignedIn() &&
                     (resource.data.reporterId == request.auth.uid || isAdmin());
      allow update: if isSignedIn() && isAdmin();
      allow delete: if false;
    }

    // ============================================
    // CONVERSATIONS COLLECTION
    // ============================================
    match /conversations/{conversationId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if false;
      
      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && 
                         request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false;
      }
    }
    
    // ============================================
    // HOST GROUPS (WhatsApp-style attendee groups)
    // ============================================
    match /hostGroups/{groupId} {
      allow read: if isSignedIn() &&
                     (resource.data.hostId == request.auth.uid ||
                      (resource.data.memberIds != null &&
                       request.auth.uid in resource.data.memberIds));
      allow create: if isSignedIn() &&
                       request.resource.data.hostId == request.auth.uid;
      // Only the host can rename / change members / delete.
      allow update, delete: if isSignedIn() &&
                               resource.data.hostId == request.auth.uid;

      match /messages/{messageId} {
        function groupMembers() {
          let g = get(/databases/$(database)/documents/hostGroups/$(groupId)).data;
          return g.hostId == request.auth.uid ||
                 (g.memberIds != null && request.auth.uid in g.memberIds);
        }
        // Host-only groups: only the host may post; members still read + vote.
        // Use get() with a default so groups without the field aren't blocked.
        function canPost() {
          let g = get(/databases/$(database)/documents/hostGroups/$(groupId)).data;
          return g.hostId == request.auth.uid ||
                 (g.get('hostOnly', false) != true &&
                  g.memberIds != null && request.auth.uid in g.memberIds);
        }
        allow read: if isSignedIn() && groupMembers();
        allow create: if isSignedIn() && canPost() &&
                         request.resource.data.senderId == request.auth.uid;
        // Members may only add themselves to readBy (read receipts). deliveredTo
        // is written server-side (Admin SDK) and bypasses rules.
        allow update: if isSignedIn() && groupMembers() &&
                         request.resource.data.diff(resource.data)
                           .affectedKeys().hasOnly(['readBy']) &&
                         request.auth.uid in request.resource.data.readBy;
        allow delete: if false;
      }

      // Group polls — only the group host creates/closes; members vote.
      match /polls/{pollId} {
        function group() {
          return get(/databases/$(database)/documents/hostGroups/$(groupId)).data;
        }
        function isMember() {
          let g = group();
          return g.hostId == request.auth.uid ||
                 (g.memberIds != null && request.auth.uid in g.memberIds);
        }
        allow read: if isSignedIn() && isMember();
        allow create: if isSignedIn() &&
                         group().hostId == request.auth.uid &&
                         request.resource.data.createdBy == request.auth.uid;
        allow update: if isSignedIn() && group().hostId == request.auth.uid;
        allow delete: if false;

        match /votes/{userId} {
          allow read: if isSignedIn() && isMember();
          allow write: if isSignedIn() && request.auth.uid == userId && isMember();
        }
      }
    }

    // ============================================
    // PROMOTIONS (featured-event purchases)
    // Server-only writes (set by the payment webhook).
    // ============================================
    match /promotions/{promotionId} {
      allow read: if isSignedIn() &&
                     (resource.data.hostId == request.auth.uid || isAdmin());
      allow create, update, delete: if false;
    }

    // ============================================
    // HOST REQUESTS COLLECTION
    // ============================================
    match /hostRequests/{requestId} {
      allow read: if isAdmin() || 
                     (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && 
                       request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }
    
    // ============================================
    // VEHICLE RENTAL MARKETPLACE (model A — partner-owned fleets)
    // ============================================
    // Rental providers/partners. Owner manages their own; anyone signed-in reads.
    match /vehicleProviders/{providerId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
                       request.resource.data.ownerId == request.auth.uid;
      allow update: if isSignedIn() &&
                       (resource.data.ownerId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() &&
                       (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    // Vehicles. Public read (browse); owner edits content. `status` transitions
    // to/from "rented" are made server-side (reserveVehicle/completeRental), and
    // the reservation transaction is the source of truth against double-booking.
    match /vehicles/{vehicleId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
                       request.resource.data.ownerId == request.auth.uid;
      allow update: if isSignedIn() &&
                       (resource.data.ownerId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() &&
                       (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    // Rentals — money-sensitive: created/updated only by Cloud Functions
    // (reserveVehicle / completeRental / expireReservations via Admin SDK).
    match /rentals/{rentalId} {
      allow read: if isSignedIn() &&
                     (resource.data.renterId == request.auth.uid ||
                      resource.data.ownerId == request.auth.uid ||
                      isAdmin());
      allow create, update, delete: if false;
    }

    // ============================================
    // DEFAULT DENY ALL
    // ============================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}