rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // HELPER FUNCTIONS
    // ============================================
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // Admin authority is primarily a Firebase Auth custom claim ({admin:true})
    // — forgery-proof and free to check (no document read). The Firestore
    // role=='admin' fallback covers any admin not yet migrated to a claim; it's
    // safe because rules forbid a user self-writing role:'admin', so the doc
    // can only say 'admin' if an existing admin set it.
    function isAdmin() {
      return isSignedIn() &&
             (request.auth.token.admin == true ||
              get(/databases/$(database)/documents/users/$(request.auth.uid))
                .data.role == 'admin');
    }

    // Approved host: the admin-granted `hostApproved` flag OR the legacy
    // role=='host'. This is the ONE unified gate — the same account that may
    // create events may publish a rental vehicle AND expose a public
    // marketplace listing (publicListing==true). get() is request-cached, so
    // the two reads below bill as one. Missing fields default to not-approved.
    function isApprovedHost() {
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid))
          .data.get('hostApproved', false) == true ||
        get(/databases/$(database)/documents/users/$(request.auth.uid))
          .data.get('role', 'user') == 'host'
      );
    }
    
    function isEventParticipant(eventId) {
      let eventData = get(/databases/$(database)/documents/events/$(eventId)).data;
      return request.auth.uid == eventData.creatorId ||
             (eventData.attendees != null && request.auth.uid in eventData.attendees);
    }

    function isEventHost(eventId) {
      let eventData = get(/databases/$(database)/documents/events/$(eventId)).data;
      return request.auth.uid == eventData.creatorId ||
             (eventData.coHosts != null && request.auth.uid in eventData.coHosts);
    }

    // Community Matching: a user is "checked in" to an event when the host has
    // recorded their QR check-in. Gates who may read match profiles.
    function isCheckedIn(eventId) {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/events/$(eventId)/checkins/$(request.auth.uid));
    }

    // Matchmaking v2 gate (P0). A user's matchmaking state lives at
    // users/{uid}.matchmaking = { consentAt, profileComplete, enabled }.
    // Consent is the minimum to opt in; consent + a complete profile + enabled is
    // the full gate for v2 surfaces (curated sets, cross-community — later phases).
    function matchmakingConsented(u) {
      return isSignedIn() &&
             get(/databases/$(database)/documents/users/$(u)).data
               .get('matchmaking', {}).get('consentAt', null) != null;
    }
    function matchmakingActive(u) {
      let mm = get(/databases/$(database)/documents/users/$(u)).data.get('matchmaking', {});
      return isSignedIn() && mm.get('consentAt', null) != null &&
             mm.get('profileComplete', false) == true && mm.get('enabled', true) == true;
    }

    // An attendee who is NOT the creator — only these users may rate an event.
    function isEventAttendeeNotCreator(eventId) {
      let eventData = get(/databases/$(database)/documents/events/$(eventId)).data;
      return request.auth.uid != eventData.creatorId &&
             eventData.attendees != null &&
             request.auth.uid in eventData.attendees;
    }
    
    function onlyUpdating(allowedFields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowedFields);
    }


    // A list field changed by EXACTLY the caller adding themselves (all prior
    // members retained + one new element = the caller). Lets a user join a
    // list without being able to add anyone else or touch other entries.
    function selfAdded(field) {
      let oldL = resource.data.get(field, []);
      let newL = request.resource.data.get(field, []);
      return newL.hasAll(oldL) && newL.size() == oldL.size() + 1 &&
             (request.auth.uid in newL) && !(request.auth.uid in oldL);
    }

    // A list field changed by EXACTLY the caller removing themselves.
    function selfRemoved(field) {
      let oldL = resource.data.get(field, []);
      let newL = request.resource.data.get(field, []);
      return oldL.hasAll(newL) && newL.size() == oldL.size() - 1 &&
             (request.auth.uid in oldL) && !(request.auth.uid in newL);
    }
    
    // ============================================
    // USERS COLLECTION
    // ============================================
    match /users/{userId} {
      allow read: if isSignedIn();
      // Server-computed reputation fields + the premium entitlement can't be
      // set by the user, not even at account creation. New accounts must be a
      // plain 'user': 'admin' is granted only by an existing admin, and 'host'
      // only by the activateHost function (see the update rule below).
      //
      // PRIVESC (fix/security-rules-privesc): hostApproved + hostConfig were
      // absent from this denylist, so a modified client could create its own
      // account with hostApproved: true. isApprovedHost() trusts that flag, so
      // the whole admin-approval step was bypassable at signup — the update
      // rule below blocked it, but create never did.
      allow create: if isSignedIn() && isOwner(userId) &&
                       !request.resource.data.keys()
                          .hasAny(['hostStats', 'carpoolStats', 'isPremium',
                                   'plan', 'matchCountByEvent',
                                   'handle', 'handleLower',
                                   'hostApproved', 'hostConfig']) &&
                       request.resource.data.get('role', 'user') == 'user';

      // The owner can edit their profile but NOT hostStats/carpoolStats (host
      // ratings + loyalty are computed server-side), nor isPremium/plan (the
      // subscription entitlements are granted server-side), nor hostApproved
      // (admin approval), nor hostConfig (set only alongside role, server-side).
      //
      // role is NOT self-settable at all. It used to allow 'user'|'host', which
      // made hosting self-grantable from a modified client and reduced the whole
      // approval step to a UI convention: isApprovedHost() below trusts
      // role == 'host'. Hosting is now granted by the activateHost callable and
      // released by deferHostType — both run with the Admin SDK, which bypasses
      // these rules — so what the UI promises is what the backend enforces.
      // 'admin' remains exclusive to the isAdmin() branch.
      //
      // 'suspended' is admin-only state (adminService.suspendUser). Without it
      // in the denylist a suspended account could simply un-suspend itself.
      // isAdmin() short-circuits above, so admins still suspend/reinstate.
      //
      // matchmaking.* stays self-writable — MatchConsent writes consentAt and
      // MatchmakingSettings writes enabled/paused, both client-side with no
      // Cloud Function behind them. But matchmaking.freeTrialEndsAt is an
      // ENTITLEMENT: curatedGate.gateFor() unlocks Curated Matching while
      // now < freeTrialEndsAt, so a self-write granted unlimited free Plus.
      // Pin that one subfield to its stored value instead of locking the map.
      allow update: if isAdmin() ||
                       (isOwner(userId) &&
                        !request.resource.data.diff(resource.data)
                          .affectedKeys()
                          .hasAny(['hostStats', 'carpoolStats', 'isPremium',
                                   'plan', 'matchCountByEvent', 'hostApproved',
                                   'handle', 'handleLower', 'role',
                                   'hostConfig', 'suspended']) &&
                        request.resource.data.get('matchmaking', {})
                          .get('freeTrialEndsAt', null) ==
                        resource.data.get('matchmaking', {})
                          .get('freeTrialEndsAt', null)) ||
                       // Cross-account push-token de-dup: any user may CLEAR a
                       // stale token (set null) on any doc, but cannot point
                       // another user's token at their own device (hijack).
                       (onlyUpdating(['pushToken', 'pushTokenUpdatedAt']) &&
                        request.resource.data.get('pushToken', null) == null);
      
      allow delete: if isOwner(userId) || isAdmin();
      
      match /stripeConnect/{document=**} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin();
      }
      
      match /notifications/{notificationId} {
        allow read: if isSignedIn() && isOwner(userId);
        allow update: if isSignedIn() && isOwner(userId);
        allow delete: if isSignedIn() && isOwner(userId);
        allow create: if false;
      }

      // User-to-user blocks — only the owner manages their own block list.
      match /blocks/{blockedUid} {
        allow read, write: if isSignedIn() && isOwner(userId);
      }

      // Private contact info (phone, …). The main users doc is world-readable
      // to signed-in users for social features, so sensitive PII lives here —
      // only the owner (and admins) may read it. Email is NOT stored here; it
      // lives in Firebase Auth and is served to admins via a Cloud Function.
      match /private/{doc} {
        allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
        allow write: if isSignedIn() && isOwner(userId);
      }
    }
    
    // ============================================
    // EVENTS COLLECTION
    // ============================================
    match /events/{eventId} {
      allow read: if isSignedIn();
      // Hosts can't self-promote for free: featured + rating-aggregate +
      // matching (Kinlo Pro) fields are set only by the server (Admin SDK).
      // Email must be verified — the ID token's forgery-proof claim, so an
      // unverified account can't publish events. Browsing (read) stays open.
      allow create: if isSignedIn() &&
                       request.auth.token.email_verified == true &&
                       request.resource.data.creatorId == request.auth.uid &&
                       request.resource.data.get('featured', false) == false &&
                       // F2: the coarse gated-location fields are server-computed
                       // (setEventLocation CF, Admin SDK) — a client can't forge them.
                       !request.resource.data.keys()
                          .hasAny(['featuredUntil', 'featuredTier',
                                   'averageRating', 'totalRatings', 'matching',
                                   'approxCoords', 'area']);

      // - Admin: full control.
      // - Creator: anything except server-owned fields (featured/* and the
      //   rating aggregates, which are written only by Cloud Functions).
      // - Any signed-in user: only the attendees list (to join/leave).
      allow update: if isSignedIn() &&
                       (isAdmin() ||
                        (resource.data.creatorId == request.auth.uid &&
                         !request.resource.data.diff(resource.data)
                           .affectedKeys()
                           .hasAny(['featured', 'featuredUntil', 'featuredTier',
                                    'averageRating', 'totalRatings', 'matching',
                                    'approxCoords', 'area'])) ||
                        // Co-hosts can edit content, but not server-owned fields
                        // nor ownership (creatorId/coHosts stay creator-managed).
                        (resource.data.coHosts != null &&
                         request.auth.uid in resource.data.coHosts &&
                         !request.resource.data.diff(resource.data)
                           .affectedKeys()
                           .hasAny(['featured', 'featuredUntil', 'featuredTier',
                                    'averageRating', 'totalRatings',
                                    'creatorId', 'coHosts', 'matching',
                                    'approxCoords', 'area'])) ||
                        // Attendees: a user may only REMOVE themselves (leave).
                        // Joining is server-side (joinEvent Cloud Function /
                        // payment webhook, Admin SDK) so capacity + payment are
                        // enforced. No one can add/remove anyone else.
                        (onlyUpdating(['attendees']) && selfRemoved('attendees')) ||
                        // Waitlist: a user may add/remove only themselves.
                        (onlyUpdating(['waitlist']) &&
                         (selfAdded('waitlist') || selfRemoved('waitlist'))) ||
                        // Wall signal (§2.4): a user toggles only their own
                        // soft-interest — cannot rewrite the whole list.
                        (onlyUpdating(['interested']) &&
                         (selfAdded('interested') || selfRemoved('interested'))));
      
      allow delete: if isSignedIn() &&
                       (resource.data.creatorId == request.auth.uid || isAdmin());

      // F2: exact location (venueName/address/exactCoords/entry notes) lives here,
      // readable ONLY by participants (creator or in attendees[] — the paid/joined
      // gate). Writes are server-only (setEventLocation CF via the Admin SDK).
      match /private/{doc} {
        allow read: if isSignedIn() && isEventParticipant(eventId);
        allow write: if false;
      }

      match /messages/{messageId} {
        allow read: if isSignedIn() && isEventParticipant(eventId);
        allow create: if isSignedIn() && 
                         isEventParticipant(eventId) &&
                         request.resource.data.senderId == request.auth.uid;
        allow update: if isSignedIn() && isEventParticipant(eventId);
        allow delete: if false;
      }
      
      match /typing/{documentId} {
        allow read: if isSignedIn() && isEventParticipant(eventId);
        allow write: if isSignedIn() && isEventParticipant(eventId);
      }

      // QR check-in — only the event host writes a check-in (scans attendee QR);
      // participants can read (e.g. to see they're checked in). This keeps
      // attendance host-authorized — attendees can't self-check-in.
      match /checkins/{userId} {
        allow read: if isSignedIn() && isEventParticipant(eventId);
        allow write: if isSignedIn() && isEventHost(eventId);
      }

      // Recap photos (Smart Wall §10) — checked-in attendees share moments
      // (uploading = explicit consent). The recap post itself is created by
      // the Cloud Function trigger (Admin SDK).
      match /recapPhotos/{photoId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() &&
                         request.resource.data.uid == request.auth.uid &&
                         exists(/databases/$(database)/documents/events/$(eventId)/checkins/$(request.auth.uid));
        allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
        allow update: if false;
      }

      // Polls — only the host creates/closes; any participant votes (own vote).
      match /polls/{pollId} {
        allow read: if isSignedIn() && isEventParticipant(eventId);
        allow create: if isSignedIn() && isEventHost(eventId) &&
                         request.resource.data.createdBy == request.auth.uid;
        allow update: if isSignedIn() && isEventHost(eventId);
        allow delete: if false;

        match /votes/{userId} {
          allow read: if isSignedIn() && isEventParticipant(eventId);
          allow write: if isSignedIn() &&
                          request.auth.uid == userId &&
                          isEventParticipant(eventId);
        }
      }

      // Car pool — a participant offers a ride; riders request seats.
      match /carpools/{carpoolId} {
        allow read: if isSignedIn() && isEventParticipant(eventId);
        allow create: if isSignedIn() && isEventParticipant(eventId) &&
                         request.resource.data.driverId == request.auth.uid;
        // Only the driver edits/closes their offer.
        allow update: if isSignedIn() &&
                         resource.data.driverId == request.auth.uid;
        allow delete: if false;

        match /riders/{userId} {
          function driverId() {
            return get(/databases/$(database)/documents/events/$(eventId)/carpools/$(carpoolId)).data.driverId;
          }
          allow read: if isSignedIn() && isEventParticipant(eventId);
          allow create: if isSignedIn() && request.auth.uid == userId &&
                           isEventParticipant(eventId);
          // Rider can edit/cancel their own request; driver can approve/decline.
          allow update: if isSignedIn() &&
                           (request.auth.uid == userId ||
                            request.auth.uid == driverId());
          allow delete: if isSignedIn() && request.auth.uid == userId;
        }
      }
    }
    
    // ============================================
    // RATINGS COLLECTION
    // ============================================
    // @handle reservation registry (spec 10). The doc id IS the lowercase
    // handle. Readable so the client can check availability + resolve a handle
    // → uid; writes ONLY via the claimHandle/adminReassignHandle Cloud Functions
    // (Admin SDK), never by clients — that's what guarantees uniqueness.
    match /handles/{handleLower} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /ratings/{ratingId} {
      allow read: if isSignedIn();
      // Only an attendee (not the host) of the rated event may create a rating,
      // as themselves, and hostId MUST be the event's real creator (prevents
      // aiming a bad rating at an arbitrary host to tank their average).
      allow create: if isSignedIn() &&
                       request.resource.data.userId == request.auth.uid &&
                       isEventAttendeeNotCreator(request.resource.data.eventId) &&
                       request.resource.data.hostId ==
                         get(/databases/$(database)/documents/events/$(request.resource.data.eventId)).data.creatorId &&
                       // One rating per user per event: deterministic doc id.
                       ratingId == request.resource.data.eventId + '_' + request.auth.uid;
      // Ratings are immutable from the client (averages are recomputed by a
      // Cloud Function); the host can't edit/inflate them.
      allow update, delete: if false;

      // Reply thread between the reviewer and the host.
      match /messages/{messageId} {
        function ratingParty() {
          let r = get(/databases/$(database)/documents/ratings/$(ratingId)).data;
          return request.auth.uid == r.userId || request.auth.uid == r.hostId;
        }
        allow read: if isSignedIn() && (ratingParty() || isAdmin());
        allow create: if isSignedIn() &&
                         request.resource.data.senderId == request.auth.uid &&
                         ratingParty();
        allow update, delete: if false;
      }
    }
    
    // ============================================
    // MEMBERSHIP PLANS (host-defined templates)
    // ============================================
    match /membershipPlans/{planId} {
      // Anyone signed in can read (buyers browse a host's plans).
      allow read: if isSignedIn();
      // A host manages only their own plans.
      allow create: if isSignedIn() &&
                       request.resource.data.hostId == request.auth.uid;
      allow update, delete: if isSignedIn() &&
                               resource.data.hostId == request.auth.uid;
    }

    // ============================================
    // MEMBERSHIPS (a user's purchased instance)
    // Credits/expiry are money-sensitive: only the server (Admin SDK via
    // Cloud Functions / webhooks) may create or mutate them.
    // ============================================
    match /memberships/{membershipId} {
      allow read: if isSignedIn() &&
                     (resource.data.userId == request.auth.uid ||
                      resource.data.hostId == request.auth.uid ||
                      isAdmin());
      allow create, update, delete: if false;
    }

    // ============================================
    // MEMBERSHIP REDEMPTIONS (credit-deduction audit trail)
    // Server-only writes (host check-in goes through a Cloud Function).
    // ============================================
    match /membershipRedemptions/{redemptionId} {
      allow read: if isSignedIn() &&
                     (resource.data.userId == request.auth.uid ||
                      resource.data.hostId == request.auth.uid ||
                      isAdmin());
      allow create, update, delete: if false;
    }

    // Pending staff invites (kinlo_business/07 FIX 4). Created/claimed only via
    // Cloud Functions (Admin SDK). The owner reads the invites they sent.
    match /staffInvites/{inviteId} {
      allow read: if isSignedIn() &&
                     (resource.data.bizId == request.auth.uid ||
                      resource.data.invitedBy == request.auth.uid ||
                      isAdmin());
      allow create, update, delete: if false;
    }

    // Ownership transfer requests (BUG 32.4). Created/decided only via Cloud
    // Functions (requestOwnerTransfer / approveOwnerTransfer). Admins review;
    // the two parties can read their own request.
    match /ownerTransfers/{transferId} {
      allow read: if isSignedIn() && (
                     isAdmin() ||
                     resource.data.fromUid == request.auth.uid ||
                     resource.data.toUid == request.auth.uid);
      allow create, update, delete: if false;
    }

    // ============================================
    // MEMBERSHIP RESERVATIONS (credit holds)
    // Created/redeemed/released only via Cloud Functions (Admin SDK).
    // ============================================
    match /membershipReservations/{reservationId} {
      allow read: if isSignedIn() &&
                     (resource.data.userId == request.auth.uid ||
                      resource.data.hostId == request.auth.uid ||
                      isAdmin());
      allow create, update, delete: if false;
    }

    // ============================================
    // PAYMENTS COLLECTION
    // ============================================
    match /payments/{paymentId} {
      allow read: if isSignedIn() && 
                     (resource.data.userId == request.auth.uid || 
                      resource.data.hostId == request.auth.uid || 
                      isAdmin());
      allow create, update, delete: if false;
    }
    
    // ============================================
    // NOTIFICATIONS COLLECTION
    // ============================================
    match /notifications/{notificationId} {
      // Owner can read their notifications
      allow read: if isSignedIn() && 
                     resource.data.userId == request.auth.uid;
      
      // Owner can update their notifications
      allow update: if isSignedIn() && 
                       resource.data.userId == request.auth.uid;
      
      // Owner can delete their notifications
      allow delete: if isSignedIn() && 
                       resource.data.userId == request.auth.uid;
      
      // Notifications are created ONLY server-side (the createNotification
      // Cloud Function, via the Admin SDK). Direct client create is denied so
      // an attacker can't forge a notification's sender or spoof a victim with
      // a fake "You're a Verified Host!" message.
      allow create: if false;
    }

    // Crash/error telemetry: write-only for users, admins read in the console.
    match /crashes/{crashId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && isAdmin();
      allow update, delete: if false;
    }

    // Social graph — follows (foundation for the future feed/posts layer).
    // Doc id = "{followerId}_{followeeId}". You manage only your own follows.
    match /follows/{followId} {
      allow read: if isSignedIn();
      // Following is IDEMPOTENT: followUser does setDoc() on the deterministic id
      // "{follower}_{followee}", which is an UPDATE (not a create) whenever the
      // doc already exists — so create and update must share one guard, or
      // re-following your own follow gets denied. The id must match the payload,
      // so followeeId can never drift from the document it's keyed by.
      allow create, update: if isSignedIn() &&
                               request.resource.data.followerId == request.auth.uid &&
                               followId == request.auth.uid + "_" + request.resource.data.followeeId;
      allow delete: if isSignedIn() &&
                       resource.data.followerId == request.auth.uid;
    }

    // Moderation reports (off-platform payment attempts, host user blocks).
    // Any signed-in user files them (reporterId must be theirs); admins read +
    // resolve. The reporter can read their own.
    match /reports/{reportId} {
      allow create: if isSignedIn() &&
                       request.resource.data.reporterId == request.auth.uid;
      allow read: if isSignedIn() &&
                     (resource.data.reporterId == request.auth.uid || isAdmin());
      allow update: if isSignedIn() && isAdmin();
      allow delete: if false;
    }

    // CONVERSATIONS — legacy/removed. DMs live in /dms (participant-scoped).
    match /conversations/{conversationId} {
      allow read, write: if false;
      match /messages/{messageId} {
        allow read, write: if false;
      }
    }
    
    // ============================================
    // HOST GROUPS (WhatsApp-style attendee groups)
    // ============================================
    match /hostGroups/{groupId} {
      allow read: if isSignedIn() &&
                     (resource.data.hostId == request.auth.uid ||
                      (resource.data.memberIds != null &&
                       request.auth.uid in resource.data.memberIds));
      // BUG 42: creating a community requires an approved host — the same unified
      // gate as vehicles + marketplace listings. Joining by code goes through a
      // Cloud Function (Admin SDK), so it stays open to everyone.
      allow create: if isSignedIn() && isApprovedHost() &&
                       request.resource.data.hostId == request.auth.uid;
      // Only the host can rename / change members / delete.
      allow update, delete: if isSignedIn() &&
                               resource.data.hostId == request.auth.uid;

      match /messages/{messageId} {
        function groupMembers() {
          let g = get(/databases/$(database)/documents/hostGroups/$(groupId)).data;
          return g.hostId == request.auth.uid ||
                 (g.memberIds != null && request.auth.uid in g.memberIds);
        }
        // Host-only groups: only the host may post; members still read + vote.
        // Use get() with a default so groups without the field aren't blocked.
        function canPost() {
          let g = get(/databases/$(database)/documents/hostGroups/$(groupId)).data;
          return g.hostId == request.auth.uid ||
                 (g.get('hostOnly', false) != true &&
                  g.memberIds != null && request.auth.uid in g.memberIds);
        }
        allow read: if isSignedIn() && groupMembers();
        allow create: if isSignedIn() && canPost() &&
                         request.resource.data.senderId == request.auth.uid;
        // Members may only add themselves to readBy (read receipts). deliveredTo
        // is written server-side (Admin SDK) and bypasses rules.
        allow update: if isSignedIn() && groupMembers() &&
                         request.resource.data.diff(resource.data)
                           .affectedKeys().hasOnly(['readBy']) &&
                         request.auth.uid in request.resource.data.readBy;
        allow delete: if false;
      }

      // Group polls — only the group host creates/closes; members vote.
      match /polls/{pollId} {
        function group() {
          return get(/databases/$(database)/documents/hostGroups/$(groupId)).data;
        }
        function isMember() {
          let g = group();
          return g.hostId == request.auth.uid ||
                 (g.memberIds != null && request.auth.uid in g.memberIds);
        }
        allow read: if isSignedIn() && isMember();
        allow create: if isSignedIn() &&
                         group().hostId == request.auth.uid &&
                         request.resource.data.createdBy == request.auth.uid;
        allow update: if isSignedIn() && group().hostId == request.auth.uid;
        allow delete: if false;

        match /votes/{userId} {
          allow read: if isSignedIn() && isMember();
          allow write: if isSignedIn() && request.auth.uid == userId && isMember();
        }
      }
    }

    // ============================================
    // PROMOTIONS (featured-event purchases)
    // Server-only writes (set by the payment webhook).
    // ============================================
    match /promotions/{promotionId} {
      allow read: if isSignedIn() &&
                     (resource.data.hostId == request.auth.uid || isAdmin());
      allow create, update, delete: if false;
    }

    // ============================================
    // HOST REQUESTS COLLECTION
    // ============================================
    match /hostRequests/{requestId} {
      allow read: if isAdmin() || 
                     (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && 
                       request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }
    
    // ============================================
    // VEHICLE RENTAL MARKETPLACE (model A — partner-owned fleets)
    // ============================================
    // Rental providers/partners. Owner manages their own; anyone signed-in reads.
    match /vehicleProviders/{providerId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
                       request.resource.data.ownerId == request.auth.uid;
      allow update: if isSignedIn() &&
                       (resource.data.ownerId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() &&
                       (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    // Vehicles. Public read (browse); owner edits content. `status` transitions
    // to/from "rented" are made server-side (reserveVehicle/completeRental), and
    // the reservation transaction is the source of truth against double-booking.
    match /vehicles/{vehicleId} {
      allow read: if isSignedIn();
      // P0 unified-host gate: only an approved host may list a vehicle. This
      // closes the model-A hole where any signed-in user could create a vehicle.
      allow create: if isSignedIn() && isApprovedHost() &&
                       request.resource.data.ownerId == request.auth.uid;
      // 'status' belongs to the rental state machine ("reserved" is written by
      // reserveVehicle, cleared by completeRental / expireReservations — all
      // Admin SDK). The owner could previously set it directly and desync that
      // machine, e.g. clear "reserved" out from under a paid reservation and
      // re-let the vehicle.
      //
      // 'ownerId' is the gate itself: create demands isApprovedHost(), but the
      // owner could then hand the vehicle to any uid — laundering a live
      // listing onto an account that was never approved, and moving it out of
      // reach of this same rule. Both are server/admin territory; admins keep
      // the escape hatch for support transfers.
      allow update: if isSignedIn() &&
                       (isAdmin() ||
                        (resource.data.ownerId == request.auth.uid &&
                         !request.resource.data.diff(resource.data)
                           .affectedKeys().hasAny(['status', 'ownerId'])));
      allow delete: if isSignedIn() &&
                       (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    // Rentals — money-sensitive: created/updated only by Cloud Functions
    // (reserveVehicle / completeRental / expireReservations via Admin SDK).
    match /rentals/{rentalId} {
      allow read: if isSignedIn() &&
                     (resource.data.renterId == request.auth.uid ||
                      resource.data.ownerId == request.auth.uid ||
                      isAdmin());
      allow create, update, delete: if false;
    }

    // ============================================
    // SOCIAL LAYER — posts / likes / comments / DMs / blocks
    // ============================================
    // Posts: readable by any signed-in user; authored as yourself. likeCount /
    // commentCount are aggregates maintained by Cloud Functions (Admin SDK), so
    // they can't be created/edited by clients.
    // Wall v2 (P2): posting to a community requires membership; an isHostPost
    // requires being that community's host. Personal posts (no communityId) are
    // unchanged and can never be host posts.
    function communityOf(cid) {
      return get(/databases/$(database)/documents/hostGroups/$(cid)).data;
    }
    function isCommunityMember(cid) {
      let g = communityOf(cid);
      return g.hostId == request.auth.uid ||
             (g.memberIds != null && request.auth.uid in g.memberIds);
    }
    function canCreatePost() {
      let cid = request.resource.data.get('communityId', null);
      let hostPost = request.resource.data.get('isHostPost', false) == true;
      return cid == null ?
        hostPost == false :
        (isCommunityMember(cid) &&
         (hostPost == false || communityOf(cid).hostId == request.auth.uid));
    }

    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
                       request.resource.data.authorId == request.auth.uid &&
                       request.resource.data.get('likeCount', 0) == 0 &&
                       request.resource.data.get('commentCount', 0) == 0 &&
                       canCreatePost();
      // Author edits only their own text/images (not the aggregate counts).
      allow update: if isSignedIn() &&
                       resource.data.authorId == request.auth.uid &&
                       !request.resource.data.diff(resource.data)
                         .affectedKeys().hasAny(['likeCount', 'commentCount', 'authorId']);
      allow delete: if isSignedIn() &&
                       (resource.data.authorId == request.auth.uid || isAdmin());

      // Likes — one per user; you like/unlike only as yourself.
      match /likes/{likeUid} {
        allow read: if isSignedIn();
        allow create, delete: if isSignedIn() && request.auth.uid == likeUid;
        allow update: if false;
      }

      // Comments — authored as yourself; deletable by the comment author, the
      // post author, or an admin.
      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() &&
                         request.resource.data.authorId == request.auth.uid;
        allow update: if false;
        allow delete: if isSignedIn() &&
                         (resource.data.authorId == request.auth.uid ||
                          get(/databases/$(database)/documents/posts/$(postId)).data.authorId == request.auth.uid ||
                          isAdmin());
      }
    }

    // Post reach stats (Wall v2 · P2, Kinlo Pro). Server-maintained impressions /
    // CTA taps; readable ONLY by the post's author (the Pro UI gates the display).
    match /postStats/{postId} {
      allow read: if isSignedIn() &&
                     get(/databases/$(database)/documents/posts/$(postId)).data.authorId == request.auth.uid;
      allow write: if false; // recordPostEvent (Admin SDK) only
    }

    // Moments (Wall v2 · P3) — ephemeral 24h media at
    // moments/{ownerId}/momentItems/{itemId}. Owner writes only their own items
    // (with the required expiresAt); any signed-in user reads (the feed filters
    // to followed authors + non-expired). Expiry is enforced server-side by
    // purgeExpiredMoments; owner (or server) may delete early.
    //
    // The subcollection is named `momentItems`, NOT `items`: the name is the
    // collection-group key, so a generic one would (a) let this rule leak to any
    // other `items` collection and (b) let the purge sweep it.
    match /moments/{ownerId}/momentItems/{itemId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
                       request.auth.uid == ownerId &&
                       request.resource.data.authorId == request.auth.uid &&
                       request.resource.data.expiresAt is timestamp;
      allow update: if false;
      allow delete: if isSignedIn() && request.auth.uid == ownerId;
    }
    // The Moments row queries ACROSS users with collectionGroup("momentItems").
    // A collection-group read is NOT covered by the nested match above — it needs
    // this recursive wildcard (CLAUDE.md §4). Read-only; every write still goes
    // through the owner-scoped rule.
    match /{path=**}/momentItems/{itemId} {
      allow read: if isSignedIn();
    }

    // Direct messages — thread id is the sorted uid pair; only the two
    // participants can read/write.
    match /dms/{threadId} {
      function participants() {
        return get(/databases/$(database)/documents/dms/$(threadId)).data.users;
      }
      allow read: if isSignedIn() &&
                     resource.data.users != null &&
                     request.auth.uid in resource.data.users;
      allow create: if isSignedIn() &&
                       request.resource.data.users is list &&
                       request.auth.uid in request.resource.data.users &&
                       request.resource.data.users.size() == 2;
      allow update: if isSignedIn() &&
                       request.auth.uid in resource.data.users;
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isSignedIn() && request.auth.uid in participants();
        allow create: if isSignedIn() &&
                         request.auth.uid in participants() &&
                         request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // ============================================
    // COMMUNITY MATCHING (Kinlo Pro feature)
    // ============================================
    // Opt-in match profiles per event. Readable only by attendees who checked
    // in to the SAME event (finer same/opposite-gender visibility is applied in
    // the grid query); each user writes only their own profile. Hidden or
    // unavailable profiles aren't exposed to peers (owner still reads their own).
    match /matchProfiles/{eventId}/attendees/{userId} {
      allow read: if isSignedIn() &&
                     (request.auth.uid == userId ||
                      (isCheckedIn(eventId) &&
                       resource.data.available == true &&
                       resource.data.visibility != 'hidden'));
      // v2 gate: opting in (creating a profile) requires prior consent
      // (users/{uid}.matchmaking.consentAt, written by MatchConsent). Updates to
      // an existing profile stay ungated so legacy profiles keep working.
      allow create: if isSignedIn() &&
                       request.auth.uid == userId &&
                       request.resource.data.userId == request.auth.uid &&
                       matchmakingConsented(request.auth.uid);
      allow update: if isSignedIn() &&
                       request.auth.uid == userId &&
                       request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }

    // Likes are PRIVATE. Only Cloud Functions (Admin SDK) read/write them, so
    // the host can NEVER see who liked whom and the per-event match cap is
    // enforced atomically server-side (createLikeAndMaybeMatch).
    match /likes/{eventId}/edges/{edgeId} {
      allow read, write: if false;
    }

    // Matches are server-created; only the two people in the pair may read.
    match /matches/{eventId}/pairs/{matchId} {
      allow read: if isSignedIn() &&
                     resource.data.users != null &&
                     request.auth.uid in resource.data.users;
      allow create, update, delete: if false;
    }

    // Match chat — the parent doc (server-created) holds the two members and the
    // allowMessaging flag; messages are gated by both.
    match /matchChats/{matchId} {
      allow read: if isSignedIn() &&
                     resource.data.users != null &&
                     request.auth.uid in resource.data.users;
      allow create, update, delete: if false;

      match /messages/{messageId} {
        function chat() {
          return get(/databases/$(database)/documents/matchChats/$(matchId)).data;
        }
        allow read: if isSignedIn() && request.auth.uid in chat().users;
        allow create: if isSignedIn() &&
                         request.auth.uid in chat().users &&
                         chat().get('allowMessaging', false) == true &&
                         request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // ============================================
    // MATCHMAKING V2 (user-level, cross-community) — P2/P3
    // ============================================
    // The weekly curated set is BUILT and GATED on the server. The owner reads
    // their own set; nobody writes it from the client (a locked set already has
    // its members withheld server-side, so a leaked read still can't unlock).
    match /curatedSets/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if false; // server-only (requestCuratedSet / weekly batch)
    }

    // "Dejar de sugerir" — the owner's private exclusion list. NOT a block (a
    // block lives in the safety layer); it only removes people from future sets.
    match /matchExclusions/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create, update: if isSignedIn() &&
                               request.auth.uid == userId &&
                               request.resource.data.ownerId == request.auth.uid;
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }

    // Intro edges are PRIVATE like likes — server-only, so expressing interest
    // never leaks. The reciprocal request (also server-side) forms the mutual
    // follow + DM thread. The parent doc's connected state is pair-readable.
    match /matchIntros/{introId} {
      allow read: if isSignedIn() &&
                     resource.data.users != null &&
                     request.auth.uid in resource.data.users;
      allow write: if false;
      match /edges/{edgeUid} {
        allow read, write: if false; // requestMatchIntro only (Admin SDK)
      }
    }

    // User-level match pool (P3): a denormalized, opt-in display profile used to
    // build curated sets cross-community. Owner writes own; readable by any
    // active matchmaking participant (the set generator reads via Admin SDK; the
    // client hydrates only the uids the server already curated FOR it).
    match /matchPool/{userId} {
      allow read: if matchmakingActive(request.auth.uid);
      allow create, update: if isSignedIn() &&
                               request.auth.uid == userId &&
                               request.resource.data.userId == request.auth.uid &&
                               matchmakingConsented(request.auth.uid);
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }

    // Match groups (P3): server-formed clusters of 4-6. A candidate can see the
    // suggestion; joining is server-only (joinMatchGroup transaction caps size +
    // flips the chat on at 3+). A joined member may only touch lastMessage.
    match /matchGroups/{groupId} {
      allow read: if isSignedIn() &&
                     (request.auth.uid in resource.data.get('candidates', []) ||
                      request.auth.uid in resource.data.get('joined', []));
      allow create, delete: if false; // formMatchGroups (Admin SDK) only
      allow update: if isSignedIn() &&
                       request.auth.uid in resource.data.get('joined', []) &&
                       request.resource.data.diff(resource.data)
                         .affectedKeys().hasOnly(['lastMessage', 'updatedAt']);

      match /messages/{messageId} {
        function group() {
          return get(/databases/$(database)/documents/matchGroups/$(groupId)).data;
        }
        allow read: if isSignedIn() && request.auth.uid in group().get('joined', []);
        allow create: if isSignedIn() &&
                         request.auth.uid in group().get('joined', []) &&
                         group().get('chatActive', false) == true &&
                         request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // ============================================
    // APP CONFIG (pricing knobs) — admin-writable, world-readable so clients
    // can show accurate fee estimates that match what the server charges.
    // ============================================
    match /config/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ============================================
    // KINLO FOR BUSINESS (host ERP/CRM) — Pro-gated in the app.
    // v1: one business per owner, so bizId == ownerUid. Access is staff-scoped:
    // a staff record at businesses/{bizId}/staff/{uid} grants access; the owner
    // (uid == bizId) always has access (also bootstraps the first staff doc).
    // Least-privilege: only the collections that exist today are allowed here;
    // later blocks (payments/attendance/…) add their own scoped rules.
    // ============================================
    // BUG 32.4: ownership is the business doc's ownerUid (source of truth), so it
    // survives a transfer — the new owner (uid != bizId) is recognized and the
    // demoted old owner (uid == bizId) is not. At CREATE time the doc doesn't
    // exist yet, so the bootstrap creator (uid == bizId) is used.
    function isBizOwnerUid(bizId) {
      return isSignedIn() && (
        !exists(/databases/$(database)/documents/businesses/$(bizId))
          ? request.auth.uid == bizId
          : get(/databases/$(database)/documents/businesses/$(bizId)).data.get('ownerUid', bizId) == request.auth.uid
      );
    }
    // BUG 32.1: an "invited" (not-yet-accepted) staff record must NOT grant
    // access — only status "active" (or a legacy/owner doc with no status field)
    // counts as staff.
    function isBizStaff(bizId) {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/businesses/$(bizId)/staff/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/businesses/$(bizId)/staff/$(request.auth.uid)).data.get('status', 'active') == 'active';
    }
    // The caller's staff role for a business (only call when isBizStaff is true).
    function bizStaffRole(bizId) {
      return get(/databases/$(database)/documents/businesses/$(bizId)/staff/$(request.auth.uid)).data.role;
    }
    // Marketplace P3: a business may publish an AT-HOME (at_customer) service only
    // if it is both verified and insured (admin-granted flags). This is the
    // server-side guarantee behind the at-home publish gate.
    function bizVerifiedInsured(bizId) {
      let b = get(/databases/$(database)/documents/businesses/$(bizId)).data;
      return b.get('verified', false) == true && b.get('insured', false) == true;
    }

    match /businesses/{bizId} {
      allow read: if isBizStaff(bizId) || isBizOwnerUid(bizId);
      allow create: if isBizOwnerUid(bizId);
      // PRIVESC (fix/security-rules-privesc): this was an unrestricted
      // staff-or-owner update, so ANY staff member could rewrite ownerUid and
      // take the business over (isBizOwnerUid reads that very field), or flip
      // verified/insured — the admin-granted flags that isVerifiedInsured()
      // uses to allow at_customer service listings. All three are granted
      // server-side (Admin SDK bypasses these rules), so no client may set them.
      allow update: if (isBizStaff(bizId) || isBizOwnerUid(bizId)) &&
                       !request.resource.data.diff(resource.data)
                         .affectedKeys()
                         .hasAny(['ownerUid', 'verified', 'insured']);
      allow delete: if isBizOwnerUid(bizId);

      // Staff roster — only the owner manages staff (v1). An invitee may read
      // their OWN staff record (any status) so the app can reflect a pending
      // invite (BUG 32.1); writes stay owner-only (accept/decline goes through
      // the respondToStaffInvite Cloud Function).
      match /staff/{staffUid} {
        allow read: if isBizStaff(bizId) || isBizOwnerUid(bizId) ||
                       (isSignedIn() && staffUid == request.auth.uid);
        allow write: if isBizOwnerUid(bizId);
      }

      // Roles & permission matrix — staff read (route guards), owner writes
      // (kinlo_business/07 FIX 4).
      match /roles/{roleId} {
        allow read: if isBizStaff(bizId) || isBizOwnerUid(bizId);
        allow write: if isBizOwnerUid(bizId);
      }

      // Member CRM records — staff read/write; the linked attendee may read
      // their OWN record (to show their credits + check-in pass).
      match /members/{memberId} {
        allow read: if isBizStaff(bizId) || isBizOwnerUid(bizId) ||
                       (isSignedIn() && resource.data.linkedUid == request.auth.uid);
        allow write: if isBizStaff(bizId) || isBizOwnerUid(bizId);
      }

      // Packages (products: class/session packs, unlimited, drop-in).
      match /packages/{packageId} {
        allow read, write: if isBizStaff(bizId) || isBizOwnerUid(bizId);
      }

      // Unified plans (packages + membership plans as one product).
      //
      // Readable by any signed-in user, unlike packages: members have to see the
      // plans they can buy. Nothing sensitive lives here — it's a price list.
      //
      // Only the OWNER writes. Staff can manage packages above, but a plan can
      // be sold online for money that lands in the owner's Stripe account, so
      // creating one is an owner decision.
      //
      // paymentModes is validated here, not just in the client: an empty array
      // is a product no channel can sell, and it would look perfectly fine in
      // the host's list.
      match /plans/{planId} {
        allow read: if isSignedIn();
        allow create, update: if isBizOwnerUid(bizId) &&
                                 request.resource.data.paymentModes is list &&
                                 request.resource.data.paymentModes.size() > 0 &&
                                 request.resource.data.paymentModes.hasOnly(['online', 'manual']);
        allow delete: if isBizOwnerUid(bizId);
      }

      // Attendance ledger (QR or manual mark-present).
      match /attendance/{recordId} {
        allow read, write: if isBizStaff(bizId) || isBizOwnerUid(bizId);
      }

      // Momentum board config (columns) + cards.
      match /momentum/{docId} {
        allow read, write: if isBizStaff(bizId) || isBizOwnerUid(bizId);
      }
      match /momentumCards/{cardId} {
        allow read, write: if isBizStaff(bizId) || isBizOwnerUid(bizId);
      }

      // Finance ledger — owner + instructor only; reception can't read finance.
      match /payments/{paymentId} {
        allow read, write: if isBizOwnerUid(bizId) ||
                              (isBizStaff(bizId) && bizStaffRole(bizId) != "reception");
      }

      // Expenses ledger (P&L) — same finance gate as payments.
      match /expenses/{expenseId} {
        allow read, write: if isBizOwnerUid(bizId) ||
                              (isBizStaff(bizId) && bizStaffRole(bizId) != "reception");
      }

      // Revenue Targets goal doc — finance data, same gate as payments/expenses.
      match /goals/{goalId} {
        allow read, write: if isBizOwnerUid(bizId) ||
                              (isBizStaff(bizId) && bizStaffRole(bizId) != "reception");
      }

      // Classes / schedule (roster + waitlist).
      match /classes/{classId} {
        allow read, write: if isBizStaff(bizId) || isBizOwnerUid(bizId);
      }

      // Private sessions. Types + availability are the host's public "menu"
      // (any signed-in user may read to request a session; write is staff).
      // Bookings are staff-only from the client; attendee requests go through
      // the requestBusinessSession Cloud Function (Admin SDK).
      match /sessionTypes/{id} {
        allow read: if isSignedIn();
        // Exposing a service to the public marketplace (publicListing==true) is
        // gated by the SAME unified host approval as rentals. Private
        // (staff-only) session types stay editable by any staff/owner.
        // Publishing needs an approved host; publishing an AT-HOME service also
        // needs a verified + insured business (Marketplace P3).
        allow create, update: if (isBizStaff(bizId) || isBizOwnerUid(bizId)) &&
                                 (request.resource.data.get('publicListing', false) != true ||
                                  isApprovedHost()) &&
                                 (request.resource.data.get('publicListing', false) != true ||
                                  request.resource.data.get('locationMode', 'at_business') != 'at_customer' ||
                                  bizVerifiedInsured(bizId));
        allow delete: if isBizStaff(bizId) || isBizOwnerUid(bizId);
      }
      match /availability/{id} {
        allow read: if isSignedIn();
        allow write: if isBizStaff(bizId) || isBizOwnerUid(bizId);
      }
      match /bookings/{id} {
        allow read, write: if isBizStaff(bizId) || isBizOwnerUid(bizId);
      }

      // Agenda block-off ("Unavailable") time — staff-managed (kinlo_business/05).
      match /agendaBlocks/{id} {
        allow read, write: if isBizStaff(bizId) || isBizOwnerUid(bizId);
      }

      // Automations: rules (staff-managed) + the delivery log (written by the
      // engine server-side; readable by staff).
      match /automations/{id} {
        allow read, write: if isBizStaff(bizId) || isBizOwnerUid(bizId);
      }
      match /messages/{id} {
        allow read: if isBizStaff(bizId) || isBizOwnerUid(bizId);
        allow write: if false; // server-only (Admin SDK)
      }
    }

    // Collection-group read of a member's OWN linked records. The attendee pass /
    // digital membership card side (getMyBusinessPasses) runs
    // collectionGroup("members").where(linkedUid == uid); a collection-group query
    // is NOT authorized by the nested businesses/{bizId}/members rule — it needs
    // this recursive-wildcard rule. Scoped to linkedUid == uid so a member can
    // only read their own records across every business (staff/owner writes stay
    // governed by the nested rule above).
    match /{path=**}/members/{memberId} {
      allow read: if isSignedIn() && resource.data.linkedUid == request.auth.uid;
    }

    // Marketplace browse (Marketplace P1): a collectionGroup('sessionTypes')
    // query for public listings needs this recursive-wildcard rule — the nested
    // businesses/{bizId}/sessionTypes rule does NOT authorize collection-group
    // reads. Scoped to publicListing==true so only published services are
    // exposed cross-business; private (staff-only) types stay hidden.
    match /{path=**}/sessionTypes/{id} {
      allow read: if isSignedIn() && resource.data.get('publicListing', false) == true;
    }

    // Marketplace buyers read their OWN service bookings across businesses
    // (Marketplace P1 · M4). A collectionGroup('bookings') query needs this
    // recursive-wildcard rule; the nested businesses/{bizId}/bookings rule is
    // staff/owner-only. Scoped to buyerUid == uid. Writes stay CF-only (money).
    match /{path=**}/bookings/{id} {
      allow read: if isSignedIn() && resource.data.get('buyerUid', null) == request.auth.uid;
    }

    // ============================================
    // DEFAULT DENY ALL
    // ============================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}