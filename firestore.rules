rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // HELPER FUNCTIONS
    // ============================================
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // Admin authority is primarily a Firebase Auth custom claim ({admin:true})
    // — forgery-proof and free to check (no document read). The Firestore
    // role=='admin' fallback covers any admin not yet migrated to a claim; it's
    // safe because rules forbid a user self-writing role:'admin', so the doc
    // can only say 'admin' if an existing admin set it.
    function isAdmin() {
      return isSignedIn() &&
             (request.auth.token.admin == true ||
              get(/databases/$(database)/documents/users/$(request.auth.uid))
                .data.role == 'admin');
    }
    
    function isEventParticipant(eventId) {
      let eventData = get(/databases/$(database)/documents/events/$(eventId)).data;
      return request.auth.uid == eventData.creatorId ||
             (eventData.attendees != null && request.auth.uid in eventData.attendees);
    }

    function isEventHost(eventId) {
      let eventData = get(/databases/$(database)/documents/events/$(eventId)).data;
      return request.auth.uid == eventData.creatorId ||
             (eventData.coHosts != null && request.auth.uid in eventData.coHosts);
    }

    // Community Matching: a user is "checked in" to an event when the host has
    // recorded their QR check-in. Gates who may read match profiles.
    function isCheckedIn(eventId) {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/events/$(eventId)/checkins/$(request.auth.uid));
    }

    // An attendee who is NOT the creator — only these users may rate an event.
    function isEventAttendeeNotCreator(eventId) {
      let eventData = get(/databases/$(database)/documents/events/$(eventId)).data;
      return request.auth.uid != eventData.creatorId &&
             eventData.attendees != null &&
             request.auth.uid in eventData.attendees;
    }
    
    function onlyUpdating(allowedFields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowedFields);
    }

    function changing(field) {
      return field in request.resource.data.diff(resource.data).affectedKeys();
    }

    // A list field changed by EXACTLY the caller adding themselves (all prior
    // members retained + one new element = the caller). Lets a user join a
    // list without being able to add anyone else or touch other entries.
    function selfAdded(field) {
      let oldL = resource.data.get(field, []);
      let newL = request.resource.data.get(field, []);
      return newL.hasAll(oldL) && newL.size() == oldL.size() + 1 &&
             (request.auth.uid in newL) && !(request.auth.uid in oldL);
    }

    // A list field changed by EXACTLY the caller removing themselves.
    function selfRemoved(field) {
      let oldL = resource.data.get(field, []);
      let newL = request.resource.data.get(field, []);
      return oldL.hasAll(newL) && newL.size() == oldL.size() - 1 &&
             (request.auth.uid in oldL) && !(request.auth.uid in newL);
    }
    
    // ============================================
    // USERS COLLECTION
    // ============================================
    match /users/{userId} {
      allow read: if isSignedIn();
      // Server-computed reputation fields + the premium entitlement can't be
      // set by the user, not even at account creation. New accounts must be a
      // plain 'user' — 'admin' is granted only by an existing admin.
      allow create: if isSignedIn() && isOwner(userId) &&
                       !request.resource.data.keys()
                          .hasAny(['hostStats', 'carpoolStats', 'isPremium',
                                   'plan', 'matchCountByEvent']) &&
                       request.resource.data.get('role', 'user') in ['user', 'host'];

      // The owner can edit their profile but NOT hostStats/carpoolStats (host
      // ratings + loyalty are computed server-side), nor isPremium/plan (the
      // subscription entitlements are granted server-side), nor hostApproved
      // (admin approval). Crucially, the owner may set role only to
      // 'user'/'host' — self-promotion to 'admin' is blocked; admin is granted
      // exclusively through the isAdmin() branch (an existing admin).
      allow update: if isAdmin() ||
                       (isOwner(userId) &&
                        !request.resource.data.diff(resource.data)
                          .affectedKeys()
                          .hasAny(['hostStats', 'carpoolStats', 'isPremium',
                                   'plan', 'matchCountByEvent', 'hostApproved']) &&
                        (!changing('role') ||
                         request.resource.data.role in ['user', 'host'])) ||
                       // Cross-account push-token de-dup: any user may CLEAR a
                       // stale token (set null) on any doc, but cannot point
                       // another user's token at their own device (hijack).
                       (onlyUpdating(['pushToken', 'pushTokenUpdatedAt']) &&
                        request.resource.data.get('pushToken', null) == null);
      
      allow delete: if isOwner(userId) || isAdmin();
      
      match /stripeConnect/{document=**} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin();
      }
      
      match /notifications/{notificationId} {
        allow read: if isSignedIn() && isOwner(userId);
        allow update: if isSignedIn() && isOwner(userId);
        allow delete: if isSignedIn() && isOwner(userId);
        allow create: if false;
      }

      // User-to-user blocks — only the owner manages their own block list.
      match /blocks/{blockedUid} {
        allow read, write: if isSignedIn() && isOwner(userId);
      }

      // Private contact info (phone, …). The main users doc is world-readable
      // to signed-in users for social features, so sensitive PII lives here —
      // only the owner (and admins) may read it. Email is NOT stored here; it
      // lives in Firebase Auth and is served to admins via a Cloud Function.
      match /private/{doc} {
        allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
        allow write: if isSignedIn() && isOwner(userId);
      }
    }
    
    // ============================================
    // EVENTS COLLECTION
    // ============================================
    match /events/{eventId} {
      allow read: if isSignedIn();
      // Hosts can't self-promote for free: featured + rating-aggregate +
      // matching (Kinlo Pro) fields are set only by the server (Admin SDK).
      allow create: if isSignedIn() &&
                       request.resource.data.creatorId == request.auth.uid &&
                       request.resource.data.get('featured', false) == false &&
                       !request.resource.data.keys()
                          .hasAny(['featuredUntil', 'featuredTier',
                                   'averageRating', 'totalRatings', 'matching']);

      // - Admin: full control.
      // - Creator: anything except server-owned fields (featured/* and the
      //   rating aggregates, which are written only by Cloud Functions).
      // - Any signed-in user: only the attendees list (to join/leave).
      allow update: if isSignedIn() &&
                       (isAdmin() ||
                        (resource.data.creatorId == request.auth.uid &&
                         !request.resource.data.diff(resource.data)
                           .affectedKeys()
                           .hasAny(['featured', 'featuredUntil', 'featuredTier',
                                    'averageRating', 'totalRatings', 'matching'])) ||
                        // Co-hosts can edit content, but not server-owned fields
                        // nor ownership (creatorId/coHosts stay creator-managed).
                        (resource.data.coHosts != null &&
                         request.auth.uid in resource.data.coHosts &&
                         !request.resource.data.diff(resource.data)
                           .affectedKeys()
                           .hasAny(['featured', 'featuredUntil', 'featuredTier',
                                    'averageRating', 'totalRatings',
                                    'creatorId', 'coHosts', 'matching'])) ||
                        // Attendees: a user may only REMOVE themselves (leave).
                        // Joining is server-side (joinEvent Cloud Function /
                        // payment webhook, Admin SDK) so capacity + payment are
                        // enforced. No one can add/remove anyone else.
                        (onlyUpdating(['attendees']) && selfRemoved('attendees')) ||
                        // Waitlist: a user may add/remove only themselves.
                        (onlyUpdating(['waitlist']) &&
                         (selfAdded('waitlist') || selfRemoved('waitlist'))) ||
                        // Wall signal (§2.4): a user toggles only their own
                        // soft-interest — cannot rewrite the whole list.
                        (onlyUpdating(['interested']) &&
                         (selfAdded('interested') || selfRemoved('interested'))));
      
      allow delete: if isSignedIn() && 
                       (resource.data.creatorId == request.auth.uid || isAdmin());
      
      match /messages/{messageId} {
        allow read: if isSignedIn() && isEventParticipant(eventId);
        allow create: if isSignedIn() && 
                         isEventParticipant(eventId) &&
                         request.resource.data.senderId == request.auth.uid;
        allow update: if isSignedIn() && isEventParticipant(eventId);
        allow delete: if false;
      }
      
      match /typing/{documentId} {
        allow read: if isSignedIn() && isEventParticipant(eventId);
        allow write: if isSignedIn() && isEventParticipant(eventId);
      }

      // QR check-in — only the event host writes a check-in (scans attendee QR);
      // participants can read (e.g. to see they're checked in). This keeps
      // attendance host-authorized — attendees can't self-check-in.
      match /checkins/{userId} {
        allow read: if isSignedIn() && isEventParticipant(eventId);
        allow write: if isSignedIn() && isEventHost(eventId);
      }

      // Recap photos (Smart Wall §10) — checked-in attendees share moments
      // (uploading = explicit consent). The recap post itself is created by
      // the Cloud Function trigger (Admin SDK).
      match /recapPhotos/{photoId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() &&
                         request.resource.data.uid == request.auth.uid &&
                         exists(/databases/$(database)/documents/events/$(eventId)/checkins/$(request.auth.uid));
        allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
        allow update: if false;
      }

      // Polls — only the host creates/closes; any participant votes (own vote).
      match /polls/{pollId} {
        allow read: if isSignedIn() && isEventParticipant(eventId);
        allow create: if isSignedIn() && isEventHost(eventId) &&
                         request.resource.data.createdBy == request.auth.uid;
        allow update: if isSignedIn() && isEventHost(eventId);
        allow delete: if false;

        match /votes/{userId} {
          allow read: if isSignedIn() && isEventParticipant(eventId);
          allow write: if isSignedIn() &&
                          request.auth.uid == userId &&
                          isEventParticipant(eventId);
        }
      }

      // Car pool — a participant offers a ride; riders request seats.
      match /carpools/{carpoolId} {
        allow read: if isSignedIn() && isEventParticipant(eventId);
        allow create: if isSignedIn() && isEventParticipant(eventId) &&
                         request.resource.data.driverId == request.auth.uid;
        // Only the driver edits/closes their offer.
        allow update: if isSignedIn() &&
                         resource.data.driverId == request.auth.uid;
        allow delete: if false;

        match /riders/{userId} {
          function driverId() {
            return get(/databases/$(database)/documents/events/$(eventId)/carpools/$(carpoolId)).data.driverId;
          }
          allow read: if isSignedIn() && isEventParticipant(eventId);
          allow create: if isSignedIn() && request.auth.uid == userId &&
                           isEventParticipant(eventId);
          // Rider can edit/cancel their own request; driver can approve/decline.
          allow update: if isSignedIn() &&
                           (request.auth.uid == userId ||
                            request.auth.uid == driverId());
          allow delete: if isSignedIn() && request.auth.uid == userId;
        }
      }
    }
    
    // ============================================
    // RATINGS COLLECTION
    // ============================================
    match /ratings/{ratingId} {
      allow read: if isSignedIn();
      // Only an attendee (not the host) of the rated event may create a rating,
      // as themselves, and hostId MUST be the event's real creator (prevents
      // aiming a bad rating at an arbitrary host to tank their average).
      allow create: if isSignedIn() &&
                       request.resource.data.userId == request.auth.uid &&
                       isEventAttendeeNotCreator(request.resource.data.eventId) &&
                       request.resource.data.hostId ==
                         get(/databases/$(database)/documents/events/$(request.resource.data.eventId)).data.creatorId &&
                       // One rating per user per event: deterministic doc id.
                       ratingId == request.resource.data.eventId + '_' + request.auth.uid;
      // Ratings are immutable from the client (averages are recomputed by a
      // Cloud Function); the host can't edit/inflate them.
      allow update, delete: if false;

      // Reply thread between the reviewer and the host.
      match /messages/{messageId} {
        function ratingParty() {
          let r = get(/databases/$(database)/documents/ratings/$(ratingId)).data;
          return request.auth.uid == r.userId || request.auth.uid == r.hostId;
        }
        allow read: if isSignedIn() && (ratingParty() || isAdmin());
        allow create: if isSignedIn() &&
                         request.resource.data.senderId == request.auth.uid &&
                         ratingParty();
        allow update, delete: if false;
      }
    }
    
    // ============================================
    // MEMBERSHIP PLANS (host-defined templates)
    // ============================================
    match /membershipPlans/{planId} {
      // Anyone signed in can read (buyers browse a host's plans).
      allow read: if isSignedIn();
      // A host manages only their own plans.
      allow create: if isSignedIn() &&
                       request.resource.data.hostId == request.auth.uid;
      allow update, delete: if isSignedIn() &&
                               resource.data.hostId == request.auth.uid;
    }

    // ============================================
    // MEMBERSHIPS (a user's purchased instance)
    // Credits/expiry are money-sensitive: only the server (Admin SDK via
    // Cloud Functions / webhooks) may create or mutate them.
    // ============================================
    match /memberships/{membershipId} {
      allow read: if isSignedIn() &&
                     (resource.data.userId == request.auth.uid ||
                      resource.data.hostId == request.auth.uid ||
                      isAdmin());
      allow create, update, delete: if false;
    }

    // ============================================
    // MEMBERSHIP REDEMPTIONS (credit-deduction audit trail)
    // Server-only writes (host check-in goes through a Cloud Function).
    // ============================================
    match /membershipRedemptions/{redemptionId} {
      allow read: if isSignedIn() &&
                     (resource.data.userId == request.auth.uid ||
                      resource.data.hostId == request.auth.uid ||
                      isAdmin());
      allow create, update, delete: if false;
    }

    // ============================================
    // MEMBERSHIP RESERVATIONS (credit holds)
    // Created/redeemed/released only via Cloud Functions (Admin SDK).
    // ============================================
    match /membershipReservations/{reservationId} {
      allow read: if isSignedIn() &&
                     (resource.data.userId == request.auth.uid ||
                      resource.data.hostId == request.auth.uid ||
                      isAdmin());
      allow create, update, delete: if false;
    }

    // ============================================
    // PAYMENTS COLLECTION
    // ============================================
    match /payments/{paymentId} {
      allow read: if isSignedIn() && 
                     (resource.data.userId == request.auth.uid || 
                      resource.data.hostId == request.auth.uid || 
                      isAdmin());
      allow create, update, delete: if false;
    }
    
    // ============================================
    // NOTIFICATIONS COLLECTION
    // ============================================
    match /notifications/{notificationId} {
      // Owner can read their notifications
      allow read: if isSignedIn() && 
                     resource.data.userId == request.auth.uid;
      
      // Owner can update their notifications
      allow update: if isSignedIn() && 
                       resource.data.userId == request.auth.uid;
      
      // Owner can delete their notifications
      allow delete: if isSignedIn() && 
                       resource.data.userId == request.auth.uid;
      
      // Notifications are created ONLY server-side (the createNotification
      // Cloud Function, via the Admin SDK). Direct client create is denied so
      // an attacker can't forge a notification's sender or spoof a victim with
      // a fake "You're a Verified Host!" message.
      allow create: if false;
    }

    // Crash/error telemetry: write-only for users, admins read in the console.
    match /crashes/{crashId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && isAdmin();
      allow update, delete: if false;
    }

    // Social graph — follows (foundation for the future feed/posts layer).
    // Doc id = "{followerId}_{followeeId}". You manage only your own follows.
    match /follows/{followId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
                       request.resource.data.followerId == request.auth.uid;
      allow delete: if isSignedIn() &&
                       resource.data.followerId == request.auth.uid;
      allow update: if false;
    }

    // Moderation reports (off-platform payment attempts, host user blocks).
    // Any signed-in user files them (reporterId must be theirs); admins read +
    // resolve. The reporter can read their own.
    match /reports/{reportId} {
      allow create: if isSignedIn() &&
                       request.resource.data.reporterId == request.auth.uid;
      allow read: if isSignedIn() &&
                     (resource.data.reporterId == request.auth.uid || isAdmin());
      allow update: if isSignedIn() && isAdmin();
      allow delete: if false;
    }

    // CONVERSATIONS — legacy/removed. DMs live in /dms (participant-scoped).
    match /conversations/{conversationId} {
      allow read, write: if false;
      match /messages/{messageId} {
        allow read, write: if false;
      }
    }
    
    // ============================================
    // HOST GROUPS (WhatsApp-style attendee groups)
    // ============================================
    match /hostGroups/{groupId} {
      allow read: if isSignedIn() &&
                     (resource.data.hostId == request.auth.uid ||
                      (resource.data.memberIds != null &&
                       request.auth.uid in resource.data.memberIds));
      allow create: if isSignedIn() &&
                       request.resource.data.hostId == request.auth.uid;
      // Only the host can rename / change members / delete.
      allow update, delete: if isSignedIn() &&
                               resource.data.hostId == request.auth.uid;

      match /messages/{messageId} {
        function groupMembers() {
          let g = get(/databases/$(database)/documents/hostGroups/$(groupId)).data;
          return g.hostId == request.auth.uid ||
                 (g.memberIds != null && request.auth.uid in g.memberIds);
        }
        // Host-only groups: only the host may post; members still read + vote.
        // Use get() with a default so groups without the field aren't blocked.
        function canPost() {
          let g = get(/databases/$(database)/documents/hostGroups/$(groupId)).data;
          return g.hostId == request.auth.uid ||
                 (g.get('hostOnly', false) != true &&
                  g.memberIds != null && request.auth.uid in g.memberIds);
        }
        allow read: if isSignedIn() && groupMembers();
        allow create: if isSignedIn() && canPost() &&
                         request.resource.data.senderId == request.auth.uid;
        // Members may only add themselves to readBy (read receipts). deliveredTo
        // is written server-side (Admin SDK) and bypasses rules.
        allow update: if isSignedIn() && groupMembers() &&
                         request.resource.data.diff(resource.data)
                           .affectedKeys().hasOnly(['readBy']) &&
                         request.auth.uid in request.resource.data.readBy;
        allow delete: if false;
      }

      // Group polls — only the group host creates/closes; members vote.
      match /polls/{pollId} {
        function group() {
          return get(/databases/$(database)/documents/hostGroups/$(groupId)).data;
        }
        function isMember() {
          let g = group();
          return g.hostId == request.auth.uid ||
                 (g.memberIds != null && request.auth.uid in g.memberIds);
        }
        allow read: if isSignedIn() && isMember();
        allow create: if isSignedIn() &&
                         group().hostId == request.auth.uid &&
                         request.resource.data.createdBy == request.auth.uid;
        allow update: if isSignedIn() && group().hostId == request.auth.uid;
        allow delete: if false;

        match /votes/{userId} {
          allow read: if isSignedIn() && isMember();
          allow write: if isSignedIn() && request.auth.uid == userId && isMember();
        }
      }
    }

    // ============================================
    // PROMOTIONS (featured-event purchases)
    // Server-only writes (set by the payment webhook).
    // ============================================
    match /promotions/{promotionId} {
      allow read: if isSignedIn() &&
                     (resource.data.hostId == request.auth.uid || isAdmin());
      allow create, update, delete: if false;
    }

    // ============================================
    // HOST REQUESTS COLLECTION
    // ============================================
    match /hostRequests/{requestId} {
      allow read: if isAdmin() || 
                     (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && 
                       request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }
    
    // ============================================
    // VEHICLE RENTAL MARKETPLACE (model A — partner-owned fleets)
    // ============================================
    // Rental providers/partners. Owner manages their own; anyone signed-in reads.
    match /vehicleProviders/{providerId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
                       request.resource.data.ownerId == request.auth.uid;
      allow update: if isSignedIn() &&
                       (resource.data.ownerId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() &&
                       (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    // Vehicles. Public read (browse); owner edits content. `status` transitions
    // to/from "rented" are made server-side (reserveVehicle/completeRental), and
    // the reservation transaction is the source of truth against double-booking.
    match /vehicles/{vehicleId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
                       request.resource.data.ownerId == request.auth.uid;
      allow update: if isSignedIn() &&
                       (resource.data.ownerId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() &&
                       (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    // Rentals — money-sensitive: created/updated only by Cloud Functions
    // (reserveVehicle / completeRental / expireReservations via Admin SDK).
    match /rentals/{rentalId} {
      allow read: if isSignedIn() &&
                     (resource.data.renterId == request.auth.uid ||
                      resource.data.ownerId == request.auth.uid ||
                      isAdmin());
      allow create, update, delete: if false;
    }

    // ============================================
    // SOCIAL LAYER — posts / likes / comments / DMs / blocks
    // ============================================
    // Posts: readable by any signed-in user; authored as yourself. likeCount /
    // commentCount are aggregates maintained by Cloud Functions (Admin SDK), so
    // they can't be created/edited by clients.
    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
                       request.resource.data.authorId == request.auth.uid &&
                       request.resource.data.get('likeCount', 0) == 0 &&
                       request.resource.data.get('commentCount', 0) == 0;
      // Author edits only their own text/images (not the aggregate counts).
      allow update: if isSignedIn() &&
                       resource.data.authorId == request.auth.uid &&
                       !request.resource.data.diff(resource.data)
                         .affectedKeys().hasAny(['likeCount', 'commentCount', 'authorId']);
      allow delete: if isSignedIn() &&
                       (resource.data.authorId == request.auth.uid || isAdmin());

      // Likes — one per user; you like/unlike only as yourself.
      match /likes/{likeUid} {
        allow read: if isSignedIn();
        allow create, delete: if isSignedIn() && request.auth.uid == likeUid;
        allow update: if false;
      }

      // Comments — authored as yourself; deletable by the comment author, the
      // post author, or an admin.
      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() &&
                         request.resource.data.authorId == request.auth.uid;
        allow update: if false;
        allow delete: if isSignedIn() &&
                         (resource.data.authorId == request.auth.uid ||
                          get(/databases/$(database)/documents/posts/$(postId)).data.authorId == request.auth.uid ||
                          isAdmin());
      }
    }

    // Direct messages — thread id is the sorted uid pair; only the two
    // participants can read/write.
    match /dms/{threadId} {
      function participants() {
        return get(/databases/$(database)/documents/dms/$(threadId)).data.users;
      }
      allow read: if isSignedIn() &&
                     resource.data.users != null &&
                     request.auth.uid in resource.data.users;
      allow create: if isSignedIn() &&
                       request.resource.data.users is list &&
                       request.auth.uid in request.resource.data.users &&
                       request.resource.data.users.size() == 2;
      allow update: if isSignedIn() &&
                       request.auth.uid in resource.data.users;
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isSignedIn() && request.auth.uid in participants();
        allow create: if isSignedIn() &&
                         request.auth.uid in participants() &&
                         request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // ============================================
    // COMMUNITY MATCHING (Kinlo Pro feature)
    // ============================================
    // Opt-in match profiles per event. Readable only by attendees who checked
    // in to the SAME event (finer same/opposite-gender visibility is applied in
    // the grid query); each user writes only their own profile. Hidden or
    // unavailable profiles aren't exposed to peers (owner still reads their own).
    match /matchProfiles/{eventId}/attendees/{userId} {
      allow read: if isSignedIn() &&
                     (request.auth.uid == userId ||
                      (isCheckedIn(eventId) &&
                       resource.data.available == true &&
                       resource.data.visibility != 'hidden'));
      allow create, update: if isSignedIn() &&
                               request.auth.uid == userId &&
                               request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }

    // Likes are PRIVATE. Only Cloud Functions (Admin SDK) read/write them, so
    // the host can NEVER see who liked whom and the per-event match cap is
    // enforced atomically server-side (createLikeAndMaybeMatch).
    match /likes/{eventId}/edges/{edgeId} {
      allow read, write: if false;
    }

    // Matches are server-created; only the two people in the pair may read.
    match /matches/{eventId}/pairs/{matchId} {
      allow read: if isSignedIn() &&
                     resource.data.users != null &&
                     request.auth.uid in resource.data.users;
      allow create, update, delete: if false;
    }

    // Match chat — the parent doc (server-created) holds the two members and the
    // allowMessaging flag; messages are gated by both.
    match /matchChats/{matchId} {
      allow read: if isSignedIn() &&
                     resource.data.users != null &&
                     request.auth.uid in resource.data.users;
      allow create, update, delete: if false;

      match /messages/{messageId} {
        function chat() {
          return get(/databases/$(database)/documents/matchChats/$(matchId)).data;
        }
        allow read: if isSignedIn() && request.auth.uid in chat().users;
        allow create: if isSignedIn() &&
                         request.auth.uid in chat().users &&
                         chat().get('allowMessaging', false) == true &&
                         request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // ============================================
    // APP CONFIG (pricing knobs) — admin-writable, world-readable so clients
    // can show accurate fee estimates that match what the server charges.
    // ============================================
    match /config/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ============================================
    // KINLO FOR BUSINESS (host ERP/CRM) — Pro-gated in the app.
    // v1: one business per owner, so bizId == ownerUid. Access is staff-scoped:
    // a staff record at businesses/{bizId}/staff/{uid} grants access; the owner
    // (uid == bizId) always has access (also bootstraps the first staff doc).
    // Least-privilege: only the collections that exist today are allowed here;
    // later blocks (payments/attendance/…) add their own scoped rules.
    // ============================================
    function isBizOwnerUid(bizId) {
      return isSignedIn() && request.auth.uid == bizId;
    }
    function isBizStaff(bizId) {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/businesses/$(bizId)/staff/$(request.auth.uid));
    }

    match /businesses/{bizId} {
      allow read: if isBizStaff(bizId) || isBizOwnerUid(bizId);
      allow create: if isBizOwnerUid(bizId);
      allow update: if isBizStaff(bizId) || isBizOwnerUid(bizId);
      allow delete: if isBizOwnerUid(bizId);

      // Staff roster — only the owner manages staff (v1).
      match /staff/{staffUid} {
        allow read: if isBizStaff(bizId) || isBizOwnerUid(bizId);
        allow write: if isBizOwnerUid(bizId);
      }

      // Member CRM records — staff read/write; the linked attendee may read
      // their OWN record (to show their credits + check-in pass).
      match /members/{memberId} {
        allow read: if isBizStaff(bizId) || isBizOwnerUid(bizId) ||
                       (isSignedIn() && resource.data.linkedUid == request.auth.uid);
        allow write: if isBizStaff(bizId) || isBizOwnerUid(bizId);
      }

      // Packages (products: class/session packs, unlimited, drop-in).
      match /packages/{packageId} {
        allow read, write: if isBizStaff(bizId) || isBizOwnerUid(bizId);
      }

      // Attendance ledger (QR or manual mark-present).
      match /attendance/{recordId} {
        allow read, write: if isBizStaff(bizId) || isBizOwnerUid(bizId);
      }

      // Momentum board config (columns) + cards.
      match /momentum/{docId} {
        allow read, write: if isBizStaff(bizId) || isBizOwnerUid(bizId);
      }
      match /momentumCards/{cardId} {
        allow read, write: if isBizStaff(bizId) || isBizOwnerUid(bizId);
      }

      // Finance ledger. (Reception-scoping — no finance read — arrives with
      // staff roles; today all staff are the owner.)
      match /payments/{paymentId} {
        allow read, write: if isBizStaff(bizId) || isBizOwnerUid(bizId);
      }
    }

    // ============================================
    // DEFAULT DENY ALL
    // ============================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}