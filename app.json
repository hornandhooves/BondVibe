{
  "expo": {
    "name": "Kinlo",
    "slug": "bondvibe",
    "owner": "hornandhooves",
    "scheme": "kinlo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/0cf2c3f2-26ad-4e9f-816f-b449085f9b10"
    },
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#7C3AED"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Kinlo to access your location to share it with your group."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#7C3AED"
        }
      ],
      "expo-web-browser",
      [
        "@stripe/stripe-react-native",
        {
          "enableGooglePay": false
        }
      ],
      "expo-font",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.629419649601-ldjobevlvjvjmsi92dfe3cpua8u1m8fk"
        }
      ],
      "./plugins/withGoogleSigninModularHeaders",
      "expo-localization"
    ],
    "extra": {
      "EXPO_PUBLIC_FIREBASE_API_KEY": "AIzaSyCLaUcFpX5KcemGsCCMHSfCz49CauUKjGc",
      "EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN": "bondvibe-dev.firebaseapp.com",
      "EXPO_PUBLIC_FIREBASE_PROJECT_ID": "bondvibe-dev",
      "EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET": "bondvibe-dev.firebasestorage.app",
      "EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID": "629419649601",
      "EXPO_PUBLIC_FIREBASE_APP_ID": "1:629419649601:web:4654e0378542001e18b4c0",
      "EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID": "629419649601-qkgnj1g9gu2fssobs2d1p2bbmqn3imqc.apps.googleusercontent.com",
      "EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID": "629419649601-ldjobevlvjvjmsi92dfe3cpua8u1m8fk.apps.googleusercontent.com",
      "EXPO_PUBLIC_SPOTIFY_CLIENT_ID": "bca4488fca8d4a3ba7531f0fa5f47af9",
      "eas": {
        "projectId": "0cf2c3f2-26ad-4e9f-816f-b449085f9b10"
      }
    },
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/icon.png",
      "bundleIdentifier": "com.bondvibe.app",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Kinlo needs access to your location to let you share it with your group.",
        "NSLocationAlwaysUsageDescription": "Kinlo needs access to your location to let you share it with your group.",
        "NSCameraUsageDescription": "Kinlo needs camera access to let you take profile pictures and share photos in events.",
        "NSPhotoLibraryUsageDescription": "Kinlo needs photo library access to let you choose profile pictures and share event photos.",
        "NSPhotoLibraryAddUsageDescription": "Kinlo needs permission to save photos to your library.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "edgeToEdgeEnabled": true,
      "icon": "./assets/icon.png",
      "package": "com.bondvibe.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#7C3AED"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
