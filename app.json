{
  "expo": {
    "name": "Kinlo",
    "slug": "kinlo",
    "owner": "hornandhooves",
    "scheme": "kinlo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/b7026dce-ba1e-4bc9-bed5-2403b8fe6c85"
    },
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#7C3AED"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Kinlo to access your location to share it with your group."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#7C3AED"
        }
      ],
      "expo-web-browser",
      [
        "@stripe/stripe-react-native",
        {
          "enableGooglePay": false
        }
      ],
      "expo-font",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.208504615505-sc6f4vc87ban4decpc0s6tjmfnoaqvco"
        }
      ],
      "./plugins/withGoogleSigninModularHeaders",
      "expo-localization",
      "@react-native-firebase/app",
      "@react-native-firebase/app-check"
    ],
    "extra": {
      "EXPO_PUBLIC_FIREBASE_API_KEY": "AIzaSyDB6h3zbFS5tMBIgVXhAP_a2MrYtjuNixA",
      "EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN": "kinlo-app-dev.firebaseapp.com",
      "EXPO_PUBLIC_FIREBASE_PROJECT_ID": "kinlo-app-dev",
      "EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET": "kinlo-app-dev.firebasestorage.app",
      "EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID": "208504615505",
      "EXPO_PUBLIC_FIREBASE_APP_ID": "1:208504615505:web:68728addd412218718be70",
      "EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID": "208504615505-svngj6b869l7bu06q5tu6t76t3rjuia7.apps.googleusercontent.com",
      "EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID": "208504615505-sc6f4vc87ban4decpc0s6tjmfnoaqvco.apps.googleusercontent.com",
      "EXPO_PUBLIC_SPOTIFY_CLIENT_ID": "bca4488fca8d4a3ba7531f0fa5f47af9",
      "eas": {
        "projectId": "b7026dce-ba1e-4bc9-bed5-2403b8fe6c85"
      }
    },
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/icon.png",
      "bundleIdentifier": "com.kinlo.app",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Kinlo needs access to your location to let you share it with your group.",
        "NSLocationAlwaysUsageDescription": "Kinlo needs access to your location to let you share it with your group.",
        "NSCameraUsageDescription": "Kinlo needs camera access to let you take profile pictures and share photos in events.",
        "NSPhotoLibraryUsageDescription": "Kinlo needs photo library access to let you choose profile pictures and share event photos.",
        "NSPhotoLibraryAddUsageDescription": "Kinlo needs permission to save photos to your library.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "edgeToEdgeEnabled": true,
      "icon": "./assets/icon.png",
      "package": "com.kinlo.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#7C3AED"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
