rules_version = '2';

// BondVibe Cloud Storage security rules.
// Note: getDownloadURL() returns a tokenized URL that is shareable and works
// across devices; these rules govern direct (gs://) access and uploads.
service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isImageUnder(maxBytes) {
      // Whitelist raster types — reject SVG (stored-XSS vector) and the
      // client-declared image/* wildcard.
      return request.resource.size < maxBytes &&
             request.resource.contentType in
               ['image/png', 'image/jpeg', 'image/jpg', 'image/webp', 'image/heic'];
    }

    // ── Business finance authorization (cross-service, mirrors firestore.rules) ──
    // The CURRENT owner of a business, read from Firestore. bizId is only the v1
    // default; ownership can move (requestOwnerTransfer/approveOwnerTransfer rewrite
    // businesses/{bizId}.ownerUid). Falls back to bizId when the doc/field is absent
    // — same semantics as firestore.rules isBizOwnerUid.
    function bizOwnerUid(bizId) {
      return firestore.exists(/databases/(default)/documents/businesses/$(bizId))
        ? firestore.get(/databases/(default)/documents/businesses/$(bizId)).data.get('ownerUid', bizId)
        : bizId;
    }
    function staffData(bizId) {
      return firestore.get(
        /databases/(default)/documents/businesses/$(bizId)/staff/$(request.auth.uid)).data;
    }
    // Active, non-reception staff — the same finance gate firestore.rules applies to
    // the payments/expenses docs (reception is excluded from finance).
    function isActiveFinanceStaff(bizId) {
      return firestore.exists(
               /databases/(default)/documents/businesses/$(bizId)/staff/$(request.auth.uid)) &&
             staffData(bizId).get('status', 'active') == 'active' &&
             staffData(bizId).get('role', 'reception') != 'reception';
    }
    // Whoever the Firestore finance gate authorizes for businesses/{bizId}: the
    // current owner or active finance staff.
    function isFinanceAuthorized(bizId) {
      return isSignedIn() &&
             (request.auth.uid == bizOwnerUid(bizId) || isActiveFinanceStaff(bizId));
    }

    // Event images — readable by any signed-in user; uploads namespaced by the
    // uploader's uid so nobody can overwrite another user's (or the host's)
    // event images. The event doc references only the host's uploaded URLs, so
    // a stranger's uid-subfolder blobs are inert.
    match /events/{eventId}/{userId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId &&
                      isImageUnder(10 * 1024 * 1024);
    }

    // Avatars — one folder per user. Anyone signed in can view; only the owner
    // can upload/replace their own avatar.
    match /avatars/{userId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() &&
                      request.auth.uid == userId &&
                      isImageUnder(5 * 1024 * 1024);
    }

    // Group photos — namespaced by uploader uid (prevents overwriting another
    // group's photo or planting moderation-evidence images).
    match /groups/{groupId}/{userId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId &&
                      isImageUnder(5 * 1024 * 1024);
    }

    // Vehicle photos — namespaced by uploader uid (prevents tampering with
    // another owner's rental-listing photos).
    match /vehicles/{vehicleId}/{userId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId &&
                      isImageUnder(10 * 1024 * 1024);
    }

    // Social post images — a user uploads under their own uid.
    match /posts/{userId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId &&
                      isImageUnder(10 * 1024 * 1024);
    }

    // Post-event recap moments — an attendee uploads under their own uid;
    // Firestore rules additionally require a check-in to register the photo.
    match /recaps/{eventId}/{userId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId &&
                      isImageUnder(10 * 1024 * 1024);
    }

    // Business expense receipts (P&L) — sensitive financial data (invoices,
    // amounts, vendor + bank details).
    //
    // LEAK (fix/security-rules-privesc): read was `isSignedIn()`, so ANY signed-in
    // user could fetch ANY business's receipts. That was scoped to `uid == bizId`.
    //
    // P1 (fix/security-rules-round2): `uid == bizId` breaks on an ownership
    // TRANSFER — bizId (the doc id) never changes, so the OLD owner kept access and
    // the NEW owner was locked out. Gate on the CURRENT ownerUid from Firestore
    // instead (read AND write), matching the Firestore finance gate, and allow
    // active finance staff who manage the expense docs. Size limit preserved.
    match /businesses/{bizId}/expenses/{fileName} {
      allow read: if isFinanceAuthorized(bizId);
      allow write: if isFinanceAuthorized(bizId) && isImageUnder(10 * 1024 * 1024);
    }

    // Marketplace service listing photos (Services P1). A service is a public
    // SessionType under businesses/{bizId}; v1 has bizId === the owner's uid, so
    // the owner uploads under their own namespace — mirrors the expenses rule
    // above. Public read: these back a browsable marketplace listing.
    match /businesses/{bizId}/services/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == bizId &&
                      isImageUnder(10 * 1024 * 1024);
    }

    // Everything else is denied by default.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
