rules_version = '2';

// BondVibe Cloud Storage security rules.
// Note: getDownloadURL() returns a tokenized URL that is shareable and works
// across devices; these rules govern direct (gs://) access and uploads.
service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isImageUnder(maxBytes) {
      // Whitelist raster types — reject SVG (stored-XSS vector) and the
      // client-declared image/* wildcard.
      return request.resource.size < maxBytes &&
             request.resource.contentType in
               ['image/png', 'image/jpeg', 'image/jpg', 'image/webp', 'image/heic'];
    }

    // Event images — readable by any signed-in user; uploads namespaced by the
    // uploader's uid so nobody can overwrite another user's (or the host's)
    // event images. The event doc references only the host's uploaded URLs, so
    // a stranger's uid-subfolder blobs are inert.
    match /events/{eventId}/{userId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId &&
                      isImageUnder(10 * 1024 * 1024);
    }

    // Avatars — one folder per user. Anyone signed in can view; only the owner
    // can upload/replace their own avatar.
    match /avatars/{userId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() &&
                      request.auth.uid == userId &&
                      isImageUnder(5 * 1024 * 1024);
    }

    // Group photos — namespaced by uploader uid (prevents overwriting another
    // group's photo or planting moderation-evidence images).
    match /groups/{groupId}/{userId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId &&
                      isImageUnder(5 * 1024 * 1024);
    }

    // Vehicle photos — namespaced by uploader uid (prevents tampering with
    // another owner's rental-listing photos).
    match /vehicles/{vehicleId}/{userId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId &&
                      isImageUnder(10 * 1024 * 1024);
    }

    // Social post images — a user uploads under their own uid.
    match /posts/{userId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId &&
                      isImageUnder(10 * 1024 * 1024);
    }

    // Post-event recap moments — an attendee uploads under their own uid;
    // Firestore rules additionally require a check-in to register the photo.
    match /recaps/{eventId}/{userId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId &&
                      isImageUnder(10 * 1024 * 1024);
    }

    // Everything else is denied by default.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
